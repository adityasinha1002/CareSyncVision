# Backend Environment Configuration Template
# Copy this to .env and update with your actual values

# ========== FLASK CONFIGURATION ==========
FLASK_ENV=production
FLASK_SECRET_KEY=your-secret-key-change-in-production
DEBUG=False

# ========== DATABASE CONFIGURATION ==========
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://caresynvision:your_secure_password@postgres:5432/caresynvision
SQLALCHEMY_DATABASE_URI=postgresql://caresynvision:your_secure_password@postgres:5432/caresynvision
SQLALCHEMY_TRACK_MODIFICATIONS=False

# ========== FILE UPLOAD ==========
UPLOAD_FOLDER=/app/uploads
MAX_UPLOAD_SIZE=52428800

# ========== CORS CONFIGURATION ==========
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000

# ========== SERVICE CONFIGURATION ==========
PORT=5000
HOST=0.0.0.0
WORKERS=4

# ========== HEALTH ENGINE THRESHOLDS ==========
ACTIVITY_THRESHOLD=30
SLEEP_QUALITY_THRESHOLD=6
RISK_SCORE_THRESHOLD=70

# ========== API KEYS (Placeholder) ==========
# Replace with actual API keys when needed
HEALTH_API_KEY=your-health-api-key
NOTIFICATION_API_KEY=your-notification-api-key

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== JWT CONFIGURATION ==========
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# ========== PRODUCTION ONLY ==========
# Uncomment and configure for production deployment
# DATABASE_URL=postgresql://prod_user:prod_password@prod_host:5432/caresynvision_prod
# FLASK_SECRET_KEY=<generate-with-openssl-rand-hex-32>
# DEBUG=False
# ALLOWED_ORIGINS=https://yourdomain.com
