# Git attributes for consistent handling across platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly declare text files
*.md text
*.yml text
*.yaml text
*.json text
*.js text
*.jsx text
*.ts text
*.tsx text
*.py text
*.sh text
*.sql text
*.env.* text

# Batch files, shell scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git
.gitattributes text
.gitignore text

# Documentation
CHANGELOG.md text
README.md text
LICENSE text
