# CareSyncVision Configuration Template
# Copy this file to .env and fill in your values
# IMPORTANT: Add .env to .gitignore (already done)

# ========== FLASK SERVER CONFIGURATION ==========
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production

# ========== WiFi Configuration for ESP32-CAM ==========
# NOTE: These should be stored in ESP32 EEPROM/Flash, not hardcoded
# See ESP32_CONFIG_GUIDE.md for setup instructions
WIFI_SSID=your-wifi-network
WIFI_PASSWORD=your-wifi-password
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ========== ESP32 Main Board Configuration ==========
ESP32_TEMP_THRESHOLD=38.5
ESP32_MOTION_THRESHOLD=500
ESP32_LIGHT_THRESHOLD=200
ESP32_SENSOR_READ_INTERVAL=2000
ESP32_ALERT_TIMEOUT=60000

# ========== ESP32-CAM Configuration ==========
CAM_CAPTURE_INTERVAL=5000
CAM_JPEG_QUALITY=10
CAM_REQUEST_TIMEOUT=30000
MAX_IMAGE_SIZE=5242880

# ========== Health Engine Configuration ==========
RISK_LOW_THRESHOLD=30
RISK_HIGH_THRESHOLD=60
SESSION_TIMEOUT=3600

# ========== Notification Configuration ==========
NOTIFY_ON_ALERT=True
DEBUG_MODE=False
ALERT_EMAIL=akx1002003@gmail.com
