# CareSyncVision Configuration Template
# Copy this file to .env and fill in your values

# WiFi Configuration for ESP32-CAM
WIFI_SSID=your-wifi-network
WIFI_PASSWORD=your-wifi-password

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG_MODE=True

# ESP32 Main Board Configuration
ESP32_TEMP_THRESHOLD=38.5
ESP32_MOTION_THRESHOLD=500
ESP32_LIGHT_THRESHOLD=200
ESP32_SENSOR_READ_INTERVAL=2000
ESP32_ALERT_TIMEOUT=60000

# ESP32-CAM Configuration
CAM_CAPTURE_INTERVAL=5000
CAM_JPEG_QUALITY=10
CAM_REQUEST_TIMEOUT=30000

# Risk Engine Configuration
RISK_LOW_THRESHOLD=30
RISK_HIGH_THRESHOLD=60

# Notification Configuration
NOTIFY_ON_ALERT=True
ALERT_EMAIL=admin@example.com
